{
  "_comment": "MCP 服务器配置。复制为 .mcp.json 后填入实际密钥（建议用环境变量）。",
  "_comment_env": "密钥通过 ${env:VAR_NAME} 引用，启动 Claude 前 export。",
  "mcpServers": {
    "github-corp": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:CORP_GITHUB_TOKEN}"
      }
    },
    "jira": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-jira"],
      "env": {
        "JIRA_HOST": "company.atlassian.net",
        "JIRA_EMAIL": "${env:JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${env:JIRA_API_TOKEN}"
      }
    },
    "vault": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-vault"],
      "env": {
        "VAULT_ADDR": "https://vault.internal.company.com",
        "VAULT_TOKEN": "${env:VAULT_TOKEN}"
      }
    },
    "postgres-readonly": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "postgresql://readonly:${env:DB_READONLY_PASSWORD}@db-replica.internal.company.com:5432/users"
      }
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${env:SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${env:SLACK_TEAM_ID}"
      }
    },
    "internal-confluence": {
      "command": "/usr/local/bin/mcp-internal-confluence",
      "args": ["--config", "/etc/claude/confluence-config.json"]
    }
  }
}
