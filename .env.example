# internal-user-service 环境变量模板
# 复制为 .env 并填入实际值
# ⚠️ .env 已在 .gitignore 中，不要提交！

# === 基础 ===
ENV=local
DEBUG=true
LOG_LEVEL=INFO

# === API ===
CORS_ORIGINS=["http://localhost:3000"]

# === 数据库（PostgreSQL）===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/users_dev
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=user-service-dev

# === SSO / JWT ===
SSO_JWKS_URL=https://sso.company.com/.well-known/jwks.json
SSO_ISSUER=sso.company.com
JWT_AUDIENCE=user-service

# === Vault（密钥管理）===
VAULT_URL=https://vault.internal.company.com
# VAULT_TOKEN 由 K8s External Secrets Operator 注入，**永不**写在这里

# === 监控（OpenTelemetry）===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# === Feature Flags ===
FEATURE_CACHE_BYPASS=false
FEATURE_READONLY_MODE=false

# === 审计日志（可选，用于中央日志系统）===
# CLAUDE_AUDIT_ENDPOINT=https://logs.company.com/claude-audit
# CLAUDE_AUDIT_TOKEN=***

# === Slack 通知（可选）===
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/***

# === 注意事项 ===
# 1. 生产环境所有密钥从 Vault 读取，**不**通过环境变量
# 2. 数据库密码用 Vault transit 加密
# 3. JWT 私钥由 SSO 管理，本服务只验证
# 4. feature flags 推荐用 LaunchDarkly
