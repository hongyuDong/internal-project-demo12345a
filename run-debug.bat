@echo off
REM ============================================================
REM  Claude Code 调试运行器 - 把 init-git.bat 输出捕获到日志
REM  解决"窗口一闪就没了"无法看错的问题
REM ============================================================

cd /d "%~dp0"

echo.
echo ============================================================
echo   调试运行 init-git.bat
echo ============================================================
echo.
echo   输出会同时显示在屏幕上 + 写入 init-git.log
echo.
echo   日志文件: %CD%\init-git.log
echo.
echo   如果脚本出错，把 log 发给团队
echo.
echo ============================================================
echo.

REM 运行 init-git.bat 并捕获输出
call init-git.bat 2>&1 | tee init-git.log

echo.
echo ============================================================
echo   调试运行结束
echo ============================================================
echo.
echo   日志: %CD%\init-git.log
echo.
echo 按任意键关闭窗口...
pause >nul
